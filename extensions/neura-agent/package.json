{
  "name": "neura-ai",
  "displayName": "Neura AI",
  "description": "Independent Neura IDE coding Composer with NVIDIA NIM code explanation, planning, file edits, diffs, checkpoints, app builds, and approved terminal commands.",
  "version": "0.1.0",
  "publisher": "neura",
  "license": "Apache-2.0",
  "icon": "media/neura-logo.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onView:neura-ai.chat",
    "onCommand:neura.openAiPanel",
    "onCommand:neura.openComposer",
    "onCommand:neura.openMissionControl",
    "onCommand:neura.configureProviders",
    "onCommand:neura.ask",
    "onCommand:neura.generatePlan",
    "onCommand:neura.runAgent",
    "onCommand:neura.buildApp",
    "onCommand:neura.shipApp",
    "onCommand:neura.editSelection",
    "onCommand:neura.explainCurrentFile",
    "onCommand:neura.reviewCurrentFileProposal",
    "onCommand:neura.acceptCurrentFileProposal",
    "onCommand:neura.rejectCurrentFileProposal",
    "onCommand:neura.reapplyCurrentFileProposal",
    "onCommand:neura.openNextPendingEdit",
    "onCommand:neura.acceptCurrentFileHunk",
    "onCommand:neura.rejectCurrentFileHunk",
    "onCommand:neura.fixWorkspaceProblems",
    "onCommand:neura.continueTrajectory",
    "onCommand:neura.applyChanges",
    "onCommand:neura.restoreCheckpoint",
    "onCommand:neura.openPreview",
    "onCommand:neura.verifyPreview",
    "onCommand:neura.rebuildSemanticIndex",
    "onCommand:neura.exportProofBundle",
    "onCommand:neura.newMcpToolCard",
    "onCommand:neura.runApprovedCommand",
    "onCommand:neura.addWorktree",
    "onCommand:neura.createBackgroundAgent",
    "onCommand:neura.createSwarmMission",
    "onCommand:neura.runSwarmMission",
    "onCommand:neura.followUpBackgroundAgent",
    "onCommand:neura.reviewBackgroundAgent",
    "onCommand:neura.reviewSwarmMission",
    "onCommand:neura.cancelSwarmMission",
    "onCommand:neura.cancelBackgroundAgent",
    "onCommand:neura.installPlugin",
    "onCommand:neura.toggleInlineCompletions",
    "onCommand:neura.syncCanvasProject"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "neura-ai",
          "title": "Neura AI",
          "icon": "media/neura-logo.svg"
        }
      ]
    },
    "views": {
      "neura-ai": [
        {
          "id": "neura-ai.chat",
          "name": "Neura Composer",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Neura IDE",
      "properties": {
        "neura.provider.order": {
          "type": "array",
          "default": ["openrouter", "ollama", "nim"],
          "description": "AI provider fallback order. Neura tries each configured provider in order for Composer, agent, planner, and background-agent chat calls.",
          "markdownDescription": "AI provider fallback order. Default: **OpenRouter → Ollama → NVIDIA NIM**.",
          "order": 1,
          "items": {
            "type": "string",
            "enum": ["openrouter", "ollama", "nim"]
          },
          "scope": "resource"
        },
        "neura.openrouter.apiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API key. Also reads OPENROUTER_API_KEY.",
          "markdownDescription": "OpenRouter API key for Neura IDE. Stored in VS Code settings or supplied by `OPENROUTER_API_KEY`. Neura redacts this value from logs and UI.",
          "order": 10,
          "scope": "machine-overridable"
        },
        "neura.openrouter.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "OpenRouter OpenAI-compatible base URL.",
          "order": 11,
          "scope": "resource"
        },
        "neura.openrouter.model": {
          "type": "string",
          "default": "",
          "description": "OpenRouter model ID, for example anthropic/claude-sonnet-4.5 or openai/gpt-4o-mini. Also reads OPENROUTER_MODEL.",
          "markdownDescription": "OpenRouter model ID, for example `anthropic/claude-sonnet-4.5`, `openai/gpt-4o-mini`, or another OpenRouter model.",
          "order": 12,
          "scope": "resource"
        },
        "neura.openrouter.httpReferer": {
          "type": "string",
          "default": "https://neura.local",
          "description": "Optional HTTP-Referer header sent to OpenRouter.",
          "scope": "resource"
        },
        "neura.openrouter.appTitle": {
          "type": "string",
          "default": "Neura IDE",
          "description": "Optional X-Title header sent to OpenRouter.",
          "scope": "resource"
        },
        "neura.ollama.apiKey": {
          "type": "string",
          "default": "",
          "description": "Ollama Cloud API key. Also reads OLLAMA_API_KEY or OLLAMA_CLOUD_API_KEY. Local Ollama endpoints do not require a key.",
          "markdownDescription": "Ollama Cloud API key. Also reads `OLLAMA_API_KEY` or `OLLAMA_CLOUD_API_KEY`. Local Ollama endpoints do not require a key.",
          "order": 20,
          "scope": "machine-overridable"
        },
        "neura.ollama.baseUrl": {
          "type": "string",
          "default": "https://ollama.com",
          "description": "Ollama base URL. Use https://ollama.com for Ollama Cloud native /api/chat, http://localhost:11434 for local native /api/chat, or http://localhost:11434/v1 for local OpenAI-compatible chat completions.",
          "order": 21,
          "scope": "resource"
        },
        "neura.ollama.model": {
          "type": "string",
          "default": "",
          "description": "Ollama model name, for example gpt-oss:20b, qwen2.5-coder:7b, or another model available to your Ollama endpoint. Also reads OLLAMA_MODEL.",
          "markdownDescription": "Ollama model name, for example `gpt-oss:20b`, `qwen2.5-coder:7b`, or another model available to your Ollama endpoint.",
          "order": 22,
          "scope": "resource"
        },
        "neura.nim.apiKey": {
          "type": "string",
          "default": "",
          "description": "NVIDIA NIM API key.",
          "markdownDescription": "**Required.** NVIDIA NIM API key used by Neura IDE Composer. This secret is never rendered in the Composer UI. Also reads `NVIDIA_NIM_API_KEY`, `NVIDIA_API_KEY`, or the existing Neura Desktop key as a fallback.",
          "order": 30,
          "scope": "machine-overridable"
        },
        "neura.nim.baseUrl": {
          "type": "string",
          "default": "https://integrate.api.nvidia.com/v1",
          "description": "OpenAI-compatible NVIDIA NIM base URL.",
          "order": 31,
          "scope": "resource"
        },
        "neura.nim.model": {
          "type": "string",
          "default": "nvidia/nemotron-3-nano-30b-a3b",
          "enum": [
            "nvidia/nemotron-3-nano-30b-a3b",
            "nvidia/llama-3.1-nemotron-nano-8b-v1",
            "moonshotai/kimi-k2.6",
            "minimaxai/minimax-m2.7",
            "qwen/qwen3-coder-480b-a35b-instruct",
            "qwen/qwen3-next-80b-a3b-instruct",
            "qwen/qwen3-next-80b-a3b-thinking",
            "bigcode/starcoder2-15b",
            "mistralai/codestral-22b-instruct-v0.1",
            "ibm/granite-34b-code-instruct",
            "ibm/granite-8b-code-instruct",
            "google/codegemma-7b",
            "meta/codellama-70b",
            "deepseek-ai/deepseek-coder-6.7b-instruct",
            "deepseek-ai/deepseek-v4-flash",
            "deepseek-ai/deepseek-v4-pro",
            "nvidia/llama-3.1-nemotron-51b-instruct"
          ],
          "description": "NVIDIA NIM model used for Neura Composer coding requests.",
          "order": 32,
          "scope": "resource"
        },
        "neura.nim.reasoning": {
          "type": "string",
          "default": "medium",
          "enum": ["low", "medium", "high"],
          "description": "Default reasoning level for Neura Composer coding requests.",
          "scope": "resource"
        },
        "neura.nim.timeoutMs": {
          "type": "number",
          "default": 45000,
          "minimum": 10000,
          "description": "Request timeout in milliseconds for Neura Composer NVIDIA NIM calls.",
          "scope": "resource"
        },
        "neura.nim.embeddings.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable dense NVIDIA NIM embeddings for the Neura semantic codebase index. Sparse local indexing remains available when this is off.",
          "scope": "resource"
        },
        "neura.nim.embeddings.baseUrl": {
          "type": "string",
          "default": "https://integrate.api.nvidia.com/v1",
          "description": "OpenAI-compatible NVIDIA NIM embeddings base URL. Defaults to the chat base URL when empty.",
          "scope": "resource"
        },
        "neura.nim.embeddings.model": {
          "type": "string",
          "default": "",
          "description": "NVIDIA NIM embedding model ID for dense semantic indexing. Leave empty to keep dense indexing disabled even when a chat model is configured.",
          "scope": "resource"
        },
        "neura.nim.embeddings.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional NVIDIA NIM embeddings API key. Falls back to the main Neura NIM API key when empty.",
          "scope": "machine-overridable"
        },
        "neura.index.sharedPath": {
          "type": "string",
          "default": "",
          "description": "Optional shared semantic index JSON path for team or multi-workspace reuse. Relative paths resolve from the workspace root.",
          "scope": "resource"
        },
        "neura.index.useShared": {
          "type": "boolean",
          "default": false,
          "description": "Load the configured shared semantic index instead of the local workspace index when available.",
          "scope": "resource"
        },
        "neura.index.publishShared": {
          "type": "boolean",
          "default": false,
          "description": "Write rebuilt semantic indexes to the configured shared semantic index path.",
          "scope": "resource"
        },
        "neura.inlineCompletions": {
          "type": "boolean",
          "default": false,
          "description": "Enable Copilot-style inline ghost text completions. Off by default to avoid background model calls.",
          "scope": "resource"
        },
        "neura.permissions.rules": {
          "type": "array",
          "default": [],
          "description": "Allow/Deny/Ask policy rules for Neura actions such as command, mcp, browser_url, file_read, file_write, and plugin.",
          "markdownDescription": "Policy rules evaluated before sensitive actions.\n```json\n[{ \"action\": \"command\", \"pattern\": \"npm test\", \"effect\": \"allow\" }, { \"action\": \"mcp\", \"pattern\": \"filesystem/delete_file\", \"effect\": \"deny\" }]\n```",
          "items": {
            "type": "object",
            "required": ["action", "pattern", "effect"],
            "properties": {
              "action": {
                "type": "string",
                "enum": ["*", "command", "mcp", "browser_url", "read_url", "file_read", "file_write", "plugin"]
              },
              "pattern": {
                "type": "string",
                "description": "Wildcard resource pattern, for example npm test, npm*, server/tool, or *.example.com."
              },
              "effect": {
                "type": "string",
                "enum": ["allow", "deny", "ask"]
              },
              "reason": {
                "type": "string"
              }
            }
          },
          "scope": "resource"
        },
        "neura.permissions.browser.allowedDomains": {
          "type": "array",
          "default": ["localhost", "127.0.0.1", "::1"],
          "description": "Browser URL allowlist for preview verification and browser agent access.",
          "items": { "type": "string" },
          "scope": "resource"
        },
        "neura.mcp.servers": {
          "type": "array",
          "default": [],
          "description": "MCP server definitions used by Neura approval cards.",
          "markdownDescription": "List MCP servers Neura can connect to. Stdio servers are available through approval cards before tool execution.",
          "items": {
            "type": "object",
            "required": ["name", "transport"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique display name."
              },
              "transport": {
                "type": "string",
                "enum": ["stdio", "sse"],
                "default": "stdio"
              },
              "command": {
                "type": "string",
                "description": "Executable for stdio MCP servers."
              },
              "args": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Command-line arguments for stdio MCP servers."
              },
              "env": {
                "type": "object",
                "description": "Extra environment variables for stdio MCP servers. Supports ${env:NAME} and ${workspaceFolder} interpolation."
              },
              "disabledTools": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Tool names disabled for this MCP server."
              },
              "capabilities": {
                "type": "object",
                "description": "Optional capability manifest metadata for this MCP server."
              },
              "url": {
                "type": "string",
                "description": "SSE endpoint URL."
              }
            }
          },
          "scope": "resource"
        }
      }
    },
    "commands": [
      {
        "command": "neura.openAiPanel",
        "title": "Neura: Open AI Panel"
      },
      {
        "command": "neura.openComposer",
        "title": "Neura: Open Composer"
      },
      {
        "command": "neura.openMissionControl",
        "title": "Neura: Open Mission Control"
      },
      {
        "command": "neura.configureProviders",
        "title": "Neura: Configure AI Providers"
      },
      {
        "command": "neura.ask",
        "title": "Neura: Explain Code"
      },
      {
        "command": "neura.generatePlan",
        "title": "Neura: Generate Plan"
      },
      {
        "command": "neura.runAgent",
        "title": "Neura: Edit Code"
      },
      {
        "command": "neura.buildApp",
        "title": "Neura: Build App / Site"
      },
      {
        "command": "neura.shipApp",
        "title": "Neura: Ship Production App"
      },
      {
        "command": "neura.editSelection",
        "title": "Neura: Edit Selection"
      },
      {
        "command": "neura.explainCurrentFile",
        "title": "Neura: Explain Current File"
      },
      {
        "command": "neura.reviewCurrentFileProposal",
        "title": "Neura: Review Pending Edit"
      },
      {
        "command": "neura.acceptCurrentFileProposal",
        "title": "Neura: Accept Current File"
      },
      {
        "command": "neura.rejectCurrentFileProposal",
        "title": "Neura: Reject Current File"
      },
      {
        "command": "neura.reapplyCurrentFileProposal",
        "title": "Neura: Reapply Current File"
      },
      {
        "command": "neura.openNextPendingEdit",
        "title": "Neura: Open Next Pending Edit"
      },
      {
        "command": "neura.acceptCurrentFileHunk",
        "title": "Neura: Accept Current File Hunk"
      },
      {
        "command": "neura.rejectCurrentFileHunk",
        "title": "Neura: Reject Current File Hunk"
      },
      {
        "command": "neura.fixWorkspaceProblems",
        "title": "Neura: Fix Workspace Problems"
      },
      {
        "command": "neura.continueTrajectory",
        "title": "Neura: Continue Last Stopped Agent Run"
      },
      {
        "command": "neura.applyChanges",
        "title": "Neura: Apply Changes"
      },
      {
        "command": "neura.restoreCheckpoint",
        "title": "Neura: Restore Checkpoint"
      },
      {
        "command": "neura.openPreview",
        "title": "Neura: Open Preview"
      },
      {
        "command": "neura.verifyPreview",
        "title": "Neura: Verify Preview"
      },
      {
        "command": "neura.rebuildSemanticIndex",
        "title": "Neura: Rebuild Semantic Index"
      },
      {
        "command": "neura.exportProofBundle",
        "title": "Neura: Export Proof of Work Bundle"
      },
      {
        "command": "neura.newMcpToolCard",
        "title": "Neura: New MCP Tool Card"
      },
      {
        "command": "neura.runApprovedCommand",
        "title": "Neura: Run Approved Command"
      },
      {
        "command": "neura.addWorktree",
        "title": "Neura: Add Git Worktree"
      },
      {
        "command": "neura.createBackgroundAgent",
        "title": "Neura: Create Background Agent Worktree"
      },
      {
        "command": "neura.createSwarmMission",
        "title": "Neura: Create Agent Swarm"
      },
      {
        "command": "neura.runSwarmMission",
        "title": "Neura: Run Agent Swarm"
