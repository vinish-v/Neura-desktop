      {
        "command": "neura.cancelSwarmMission",
        "title": "Neura: Cancel Agent Swarm"
      },
      {
        "command": "neura.cancelBackgroundAgent",
        "title": "Neura: Cancel Background Agent"
      },
      {
        "command": "neura.installPlugin",
        "title": "Neura: Install Plugin from Git"
      },
      {
        "command": "neura.toggleInlineCompletions",
        "title": "Neura: Toggle Inline Completions"
      },
      {
        "command": "neura.syncCanvasProject",
        "title": "Neura: Sync Workspace"
      }
    ]
  }
